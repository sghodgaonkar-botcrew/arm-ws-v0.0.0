    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug mc_tester",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/dds_bridge/cpp_plugins/build/mc_tester",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/dds_bridge/cpp_plugins",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build mc_tester",
            "miDebuggerPath": "/usr/bin/gdb"
        },
